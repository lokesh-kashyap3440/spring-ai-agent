flowchart TB
    subgraph Clients["MCP Clients"]
        direction TB
        Client1["JSON-RPC Client"]
        Client2["SSE Client"]
    end

    subgraph SpringBoot["Spring Boot Application (Port 8082)"]
        direction TB
        
        subgraph MCP["MCP Server Controller"]
            direction TB
            SSE["GET /mcp/sse"]
            RPC["POST /mcp"]
            MSG["POST /mcp/message"]
        end
        
        subgraph Agent["ReAct Agent"]
            direction TB
            ReAct["Thought → Action → Observation"]
            MaxIter["Max 10 iterations"]
        end
        
        subgraph Services["Services"]
            direction LR
            ToolReg["Tool Registry"]
            Mem["Agent Memory Service"]
            OllamaSvc["Ollama Service"]
            KafkaPub["Kafka Event Publisher"]
        end
        
        subgraph Tools["Available Tools"]
            direction TB
            Weather["get_weather"]
            News["get_news"]
            Calc["calculate"]
            DB["query_database"]
            RAG["rag_search"]
            Upload["upload_document"]
        end
        
        VectorStore["SimpleVectorStore<br/>(In-Memory RAG)"]
    end

    subgraph Infrastructure["Infrastructure"]
        direction TB
        Redis[("Redis<br/>Port 6380")]
        Kafka[("Kafka<br/>Port 9093")]
    end

    subgraph Ollama["Ollama (Port 11434)"]
        direction TB
        LLM["qwen3.5:4b"]
        Embed["nomic-embed-text"]
    end

    %% Connections
    Client1 --> RPC
    Client2 --> SSE
    Client1 -.->|SSE Events | Client2
    
    SSE --> MCP
    RPC --> MCP
    MSG --> MCP
    MCP --> Agent
    
    Agent --> ToolReg
    Agent --> Mem
    Agent --> OllamaSvc
    
    ToolReg --> Tools
    Tools --> VectorStore
    
    Mem <--> Redis
    KafkaPub --> Kafka
    OllamaSvc <--> Ollama
    
